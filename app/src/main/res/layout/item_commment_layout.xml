<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="10dp"
        android:background="@drawable/bg_search_movie_bar"
        android:paddingHorizontal="10dp"
        android:layout_marginHorizontal="10dp">

        <TextView
            android:id="@+id/tv_sender"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:paddingStart="5dp"
            android:paddingVertical="14dp"
            android:text="Xxxxx:"
            android:textSize="18dp"
            android:textColor="@color/tv_primary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tv_content"/>

        <TextView
            android:id="@+id/tv_content"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:text="xxxxxxxxxxx"
            android:textSize="18dp"
            android:paddingVertical="14dp"
            android:textColor="@color/tv_primary"
            app:layout_constraintStart_toEndOf="@id/tv_sender"
            app:layout_constraintTop_toTopOf="@id/tv_sender"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>